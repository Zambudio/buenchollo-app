# ══════════════════════════════════════════════════════════════════════════════
#  BuenChollo API — Variables de entorno
#  Copia este archivo a .env y rellena los valores reales.
#  NUNCA subas .env a control de versiones.
# ══════════════════════════════════════════════════════════════════════════════

# ── Aplicación ────────────────────────────────────────────────────────────────
APP_NAME="BuenChollo API"
# Entorno: local | staging | production
APP_ENV=local
# Nivel de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Formato de log: json (recomendado en producción/Docker, parseable por Loki/ELK)
# o text (legible, recomendado en desarrollo local).
LOG_FORMAT=json
# Rate limiting (slowapi). False sólo si quieres bombardear endpoints para tests.
RATE_LIMIT_ENABLED=true
# Scheduler de mantenimiento dentro del proceso web. Poner a false SOLO si el
# scheduler corre en contenedor dedicado (python -m app.run_scheduler) — ver
# docker-compose.yml. Imprescindible antes de usar uvicorn --workers N.
SCHEDULER_ENABLED=true

# ── Sentry / GlitchTip (error tracking opcional) ──────────────────────────────
# Dejar vacío para desactivar. Sin DSN no se envía nada y la app funciona normal.
# Obtener el DSN en sentry.io → Settings → Projects → Client Keys (DSN).
# Funciona también con GlitchTip self-hosted (mismo formato).
SENTRY_DSN=
# Etiqueta del entorno enviada con cada evento. Si lo dejas vacío, hereda APP_ENV.
SENTRY_ENVIRONMENT=
# Sample rate de "transactions" (performance monitoring). 0.0 = sólo errores.
# Subir si quieres traces. Cobra cuota en el plan free, dejar en 0.0 por defecto.
SENTRY_TRACES_SAMPLE_RATE=0.0
# Versión de la app — útil para correlacionar errores con despliegues.
SENTRY_RELEASE=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Lista de orígenes permitidos separados por comas.
# ¡NUNCA dejar "*" en producción! Si APP_ENV=production y CORS_ORIGINS
# contiene "*", el backend emite un WARNING al arrancar (ver core/main.py).
# Ejemplo producción: CORS_ORIGINS=https://buenchollotech.com,https://www.buenchollotech.com
# Para dev local con frontend Vite: http://localhost:8080,http://localhost:8081
CORS_ORIGINS=http://localhost:8080

# ── Base de datos (Supabase / PostgreSQL) ─────────────────────────────────────
# Usar el endpoint de Connection Pooling de Supabase (puerto 6543, modo transacción).
# Cambia postgresql:// por postgresql+asyncpg:// para la conexión asíncrona de SQLAlchemy.
DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT-REF]:[DB-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ── Supabase (Auth y Storage) ─────────────────────────────────────────────────
# URL del proyecto Supabase (sin /rest/v1/)
SUPABASE_URL=https://[PROJECT-REF].supabase.co
# La service_role key (privada) para que el backend pueda validar JWTs y saltarse RLS.
# NO uses la anon key aquí. La service_role key empieza con "eyJ..." y tiene el claim "role":"service_role".
SUPABASE_KEY=eyJ...service_role_key...
# OPCIONAL — secreto HS256 legacy de Supabase Auth (Settings → API → JWT Secret).
# Solo necesario si el proyecto firmara los JWT con HS256. Con claves asimétricas
# (ES256/RS256, el caso actual) la verificación usa el JWKS público y esto queda vacío.
# Ver ADR-010.
SUPABASE_JWT_SECRET=

# ── Amazon Product Advertising API ────────────────────────────────────────────
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_AFFILIATE_TAG=buenchollo0b-21
# Versión del protocolo de credenciales LWA (no cambiar salvo indicación de Amazon)
AMAZON_API_VERSION=3.2
AMAZON_CREDENTIAL_VERSION=
AMAZON_MARKETPLACE=www.amazon.es
AMAZON_AUTH_ENDPOINT=https://api.amazon.co.uk/auth/o2/token
AMAZON_OAUTH_SCOPE=creatorsapi::default

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Telegram ──────────────────────────────────────────────────────────────────
# Token del bot: obtenerlo con @BotFather en Telegram
TELEGRAM_BOT_TOKEN=
# ID del canal principal donde publicar chollos (ej: -1001234567890)
TELEGRAM_MAIN_CHANNEL_ID=
# ID del canal de administradores/pruebas (ej: -1001234567891)
TELEGRAM_ADMIN_CHANNEL_ID=
