# ══════════════════════════════════════════════════════════════════════════════
#  buenchollo-web — Variables de entorno
#  Copia este archivo a .env.local y rellena los valores reales.
#  NUNCA subas .env.local a control de versiones.
# ══════════════════════════════════════════════════════════════════════════════

# ── Supabase (Auth y Storage) ─────────────────────────────────────────────────
# URL del proyecto Supabase
VITE_SUPABASE_URL=https://[PROJECT-REF].supabase.co

# Anon key (pública) — para autenticación y subida de imágenes a Storage.
# Esta clave es segura para el cliente. NO uses la service_role key aquí.
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...anon_key...

# ── API Backend ───────────────────────────────────────────────────────────────
# URL base de buenchollo-api.
# En local (dev): http://localhost:8000
# En producción:  https://[tu-ddns]:8000
VITE_API_URL=http://localhost:8000
