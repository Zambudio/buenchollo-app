# Plantilla para probar el frontend contra la API en local en vez de
# producción. Copia este archivo a ".env.local" (ya ignorado por git,
# ver .gitignore) cuando quieras hacer estas pruebas:
#
#   cp .env.local.example .env.local
#
# Necesitas la API corriendo en local en otra terminal:
#
#   cd ../buenchollo-api && ./scripts/dev_local.sh
#
# Cuando termines de probar, borra ".env.local" (o coméntalo) para que
# `npm run dev` vuelva a apuntar a la API de producción por defecto.
VITE_API_URL=http://localhost:8000
